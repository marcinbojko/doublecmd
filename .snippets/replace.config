# Repository-specific configuration for replace.sh

# Nuspec file path (relative to script location)
NUSPEC_FILE="../doublecmd.nuspec"

# GitHub organization/user name
GITHUB_ORG="doublecmd"

# Download URLs - Available variables: $GITHUB_ORG, $id, $version
# Note: Escape $ with \$ to prevent immediate expansion
#
# Double Commander releases both 32-bit and 64-bit MSI installers
# URL format: https://github.com/doublecmd/doublecmd/releases/download/v{version}/doublecmd-{version}.{arch}.msi
URL64="https://github.com/\$GITHUB_ORG/\$id/releases/download/v\$version/\${id}-\${version}.x86_64-win64.msi"
URL="https://github.com/\$GITHUB_ORG/\$id/releases/download/v\$version/\${id}-\${version}.i386-win32.msi"
CHECKSUMS_URL=""
CHECKSUM_GREP_PATTERN=""
#

# Expected git author email hash (SHA256)
# Generate with: echo -n "your@email.com" | sha256sum | cut -d' ' -f1
EXPECTED_EMAIL_HASH="94c2fffffea6422009dcd54c1a6adfc9d19d18c53a2b66de66051fa353566f15"
